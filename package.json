{
  "name": "tentwenty-qa-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,worker -c blue,magenta \"pnpm --filter web dev\" \"pnpm --filter web run worker\"",
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter web run worker",
    "build": "pnpm --filter web build",
    "db:generate": "pnpm --filter @tentwenty/db generate",
    "db:migrate": "pnpm --filter @tentwenty/db migrate",
    "db:seed": "pnpm --filter @tentwenty/db seed",
    "db:studio": "pnpm --filter @tentwenty/db studio"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "dotenv-cli": "^11.0.0"
  }
}
