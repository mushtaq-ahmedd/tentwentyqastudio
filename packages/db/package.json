{
  "name": "@tentwenty/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "dotenv -e ../../.env.local -- prisma generate",
    "migrate": "dotenv -e ../../.env.local -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env.local -- prisma migrate deploy",
    "seed": "dotenv -e ../../.env.local -- tsx prisma/seed.ts",
    "studio": "dotenv -e ../../.env.local -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "prisma": "^6.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
