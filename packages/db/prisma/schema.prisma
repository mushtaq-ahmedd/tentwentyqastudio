// tentwenty QA Studio — Core Platform schema.
// Entity chain and field sourcing: docs/05-database-and-api.md, docs/03-system-and-engine-architecture.md.
// Every model maps 1:1 onto an existing frontend type in apps/web/src/lib/types — this schema
// is the real-data replacement for that mock layer, not a redesign of its shape.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase's pooled (pgbouncer) connection doesn't support migrations — Prisma uses this
  // direct connection for `migrate` while the app uses the pooled DATABASE_URL at runtime.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Users & Roles
// ---------------------------------------------------------------------------

enum UserRole {
  ADMINISTRATOR
  QA_LEAD
  QA_ENGINEER
  VIEWER
}

enum UserStatus {
  ACTIVE
  DISABLED
  INVITED
}

/// Mirrors Supabase Auth's `auth.users` by id (see docs/05 "Resolved decision" note on Supabase
/// Auth) — this table holds the platform-specific profile/role data Supabase Auth doesn't.
model User {
  id            String     @id @default(uuid()) @db.Uuid
  name          String
  email         String     @unique
  role          UserRole   @default(QA_ENGINEER)
  status        UserStatus @default(INVITED)
  lastActiveAt  DateTime?  @map("last_active_at")
  createdAt     DateTime   @default(now()) @map("created_at")

  projects      Project[]  @relation("ProjectOwner")
  auditsStarted Audit[]    @relation("AuditStartedBy")
  reports       Report[]   @relation("ReportGeneratedBy")

  @@map("users")
}

// ---------------------------------------------------------------------------
// Projects & Environments
// ---------------------------------------------------------------------------

enum ProjectStatus {
  READY
  READY_WITH_WARNINGS
  NOT_READY
}

model Project {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  description  String        @default("")
  clientName   String        @map("client_name") @default("")
  baseUrl      String        @map("base_url") @default("")
  figmaFileUrl String?       @map("figma_file_url")
  /// Figma personal access token (docs/04 Figma Engine, docs/08 Figma REST API). Plain string —
  /// same simplification as Environment.encryptedCreds below (the "encrypted" naming there is
  /// aspirational; no real encryption-at-rest exists yet for either field). Never sent to the
  /// client — read server-side only, by the Orchestrator when building an Engine's Configuration.
  figmaAccessToken String?     @map("figma_access_token")
  status       ProjectStatus @default(NOT_READY)
  ownerId      String        @map("owner_id") @db.Uuid
  owner        User          @relation("ProjectOwner", fields: [ownerId], references: [id])
  createdAt    DateTime      @default(now()) @map("created_at")
  /// Soft-archive — hidden from the main Projects list but never deleted (docs/09: "hidden but
  /// restorable"). Distinct from an actual delete, which is a separate, permanent action.
  archivedAt   DateTime?     @map("archived_at")

  /// Validation config overrides (docs/03 "Configuration Hierarchy: Global -> Project ->
  /// Environment"). Null means "inherit from the Global PlatformSettings row" — same vocabulary
  /// as PlatformSettings itself, since the doc never specifies field names beyond naming the
  /// three levels. Resolved by packages/core/src/engine-config.ts, never read directly by Engines.
  screenshotQuality     String? @map("screenshot_quality")
  defaultTimeoutSeconds Int?    @map("default_timeout_seconds")
  retryCount            Int?    @map("retry_count")
  defaultViewport       String? @map("default_viewport")

  environments      Environment[]
  knowledgeSources  KnowledgeSource[]
  audits            Audit[]
  reports           Report[]
  figmaFileCache    FigmaFileCache[]
  pageScreenshots   PageScreenshot[]

  @@index([ownerId])
  @@map("projects")
}

/// Durable record of every page screenshot the Browser Engine captures, independent of whether
/// any Finding ever references it as Evidence — a Finding only exists where a Validation engine
/// found something, but the Visual Engine needs the most recent PRIOR audit's screenshot for a
/// page regardless of whether that prior audit produced any findings on it (docs/04 Visual
/// Engine: "Reference Screenshot → Current Screenshot → Pixel Comparison").
model PageScreenshot {
  id             String   @id @default(uuid()) @db.Uuid
  projectId      String   @map("project_id") @db.Uuid
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  auditId        String   @map("audit_id") @db.Uuid
  pageUrl        String   @map("page_url")
  screenshotPath String   @map("screenshot_path")
  capturedAt     DateTime @default(now()) @map("captured_at")

  @@index([projectId, pageUrl, capturedAt])
  @@map("page_screenshots")
}

/// Figma Engine cache (docs/04 "Rule: parsed Figma data must be cached — never re-download the
/// same design repeatedly"; docs/08 names Redis for this, but per the same interim-simplification
/// pattern as the Orchestrator's missing job queue, this uses Postgres — no cache infra is
/// provisioned yet). `frames` stores the extracted top-level frame/component summary, not the
/// raw Figma document tree (which can be many MB) — "prepare design data for comparison" (docs/04)
/// implies a distilled structure, not an archive of the original file.
model FigmaFileCache {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fileKey      String   @map("file_key")
  /// Figma's own last-edited timestamp (from the cheap `/meta` endpoint) — compared against on
  /// each audit to decide whether the full file needs re-fetching.
  lastModified String   @map("last_modified")
  frames       Json
  /// Text-bearing descendant nodes recursively extracted from each frame — the Element Matching
  /// Engine's primary matching signal (docs/04). Added alongside `frames`, not merged into it, so
  /// each stays independently readable.
  elements     Json     @default("[]")
  fetchedAt    DateTime @default(now()) @map("fetched_at")

  @@unique([projectId, fileKey])
  @@map("figma_file_cache")
}

enum EnvironmentAuthStatus {
  VERIFIED
  NOT_CONFIGURED
}

model Environment {
  id         String                 @id @default(uuid()) @db.Uuid
  projectId  String                 @map("project_id") @db.Uuid
  project    Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  url        String
  loginUrl   String?                @map("login_url")
  online     Boolean                @default(true)
  authStatus EnvironmentAuthStatus  @default(NOT_CONFIGURED) @map("auth_status")
  notes      String                 @default("")

  // Auth credentials for the audited environment (never the platform's own auth) — encrypted at
  // rest. Never logged, per docs/10/docs/11's secrets rules.
  authMethod     String? @map("auth_method")
  encryptedCreds String? @map("encrypted_creds")

  /// Validation config overrides — the innermost, highest-precedence level of docs/03's Global ->
  /// Project -> Environment hierarchy. Null means "inherit from Project (which may itself inherit
  /// from Global)". See Project's matching fields above for the shared rationale.
  screenshotQuality     String? @map("screenshot_quality")
  defaultTimeoutSeconds Int?    @map("default_timeout_seconds")
  retryCount            Int?    @map("retry_count")
  defaultViewport       String? @map("default_viewport")

  audits Audit[]

  @@index([projectId])
  @@map("environments")
}

enum KnowledgeSourceType {
  REQUIREMENTS_DOCUMENT
  BRD
  PRD
  ACCEPTANCE_CRITERIA
  TEST_CASES
  BUSINESS_RULES
  CONTENT_SHEETS
  FIGMA_DESIGN
}

enum KnowledgeSourceStatus {
  PROCESSING
  PROCESSED
  /// Real parsing was attempted and failed (e.g. a Content Sheet CSV with no valid rows) — an
  /// honest terminal state rather than leaving it stuck at PROCESSING forever (docs/03 "no engine
  /// or ingestion step may silently fail without a visible status").
  FAILED
}

model KnowledgeSource {
  id         String                @id @default(uuid()) @db.Uuid
  projectId  String                @map("project_id") @db.Uuid
  project    Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  type       KnowledgeSourceType
  /// Object storage path (Supabase Storage) — file contents never live in Postgres.
  storagePath String?              @map("storage_path")
  /// Structured, parsed form of the source file — currently only populated for CONTENT_SHEETS
  /// (an array of {page, element, expectedText} rows; see packages/core/src/content-sheet.ts).
  /// Parsed once at upload time so the Content Engine never re-parses CSV mid-audit — same
  /// caching rationale as FigmaFileCache.
  parsedContent Json?              @map("parsed_content")
  uploadedBy String                @map("uploaded_by")
  uploadedAt DateTime              @default(now()) @map("uploaded_at")
  status     KnowledgeSourceStatus @default(PROCESSING)

  @@index([projectId])
  @@map("knowledge_sources")
}

// ---------------------------------------------------------------------------
// Audits, Pages, Engine Results
// ---------------------------------------------------------------------------

enum AuditStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

/// docs/09's business-capability language — Accessibility intentionally excluded from this V1
/// enum per CLAUDE.md's V1 Scope Fence; add it back only when V2 accessibility validation ships.
enum ValidationType {
  UI_VALIDATION
  FIGMA_COMPARISON
  CONTENT_VALIDATION
  GRAMMAR_VALIDATION
  FUNCTIONAL_VALIDATION
  BROWSER_VALIDATION
}

/// docs/03 Engine Categories — kept as one enum across Collection/Validation/Processing engines
/// since Audit/EngineResult/Finding all reference "which engine" the same way.
enum EngineName {
  DISCOVERY
  BROWSER
  FIGMA
  ELEMENT_MATCHING
  UI_VALIDATION
  VISUAL
  CONTENT
  FUNCTIONAL
  BROWSER_VALIDATION
  ACCESSIBILITY
  PERFORMANCE
  SECURITY
  CONFIDENCE
  EVIDENCE
  AI
  REPORT
}

enum EngineStatus {
  WAITING
  RUNNING
  COMPLETED
  FAILED
}

/// Immutable after `status` reaches COMPLETED/FAILED/CANCELLED — docs/05 "Audit Immutability".
/// Enforce via application-layer checks (a DB trigger is the stronger version; add one before
/// production per docs/11's migration-safety notes if this proves easy to violate accidentally).
model Audit {
  id              String         @id @default(uuid()) @db.Uuid
  runNumber       Int            @default(autoincrement()) @map("run_number")
  projectId       String         @map("project_id") @db.Uuid
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environmentId   String         @map("environment_id") @db.Uuid
  environment     Environment    @relation(fields: [environmentId], references: [id])
  status          AuditStatus    @default(QUEUED)
  validationTypes ValidationType[] @map("validation_types")
  startedById     String         @map("started_by_id") @db.Uuid
  startedBy       User           @relation("AuditStartedBy", fields: [startedById], references: [id])

  currentEngine   EngineName?    @map("current_engine")
  currentActivity String?        @map("current_activity")
  progressPercent Int            @default(0) @map("progress_percent")

  /// AI Engine output (docs/06) — an audit-level narrative summary. Purely additive: nothing
  /// about the audit's actual result depends on this being present. Null if the AI Engine wasn't
  /// configured, or its provider call failed — docs/06 "AI failure must never block report
  /// generation."
  aiExecutiveSummary String? @map("ai_executive_summary")

  startedAt DateTime  @default(now()) @map("started_at")
  endedAt   DateTime? @map("ended_at")

  pages         Page[]
  findings      Finding[]
  engineResults EngineResult[]
  reports       Report[]

  @@index([projectId])
  @@index([environmentId])
  @@index([status])
  @@index([startedAt])
  @@map("audits")
}

model EngineResult {
  id             String       @id @default(uuid()) @db.Uuid
  auditId        String       @map("audit_id") @db.Uuid
  audit          Audit        @relation(fields: [auditId], references: [id], onDelete: Cascade)
  engine         EngineName
  status         EngineStatus @default(WAITING)
  durationSeconds Int?        @map("duration_seconds")
  findingsCount  Int          @default(0) @map("findings_count")
  errorCount     Int          @default(0) @map("error_count")

  @@index([auditId])
  @@map("engine_results")
}

enum PageStatus {
  PENDING
  VALIDATED
  FAILED
}

model Page {
  id      String     @id @default(uuid()) @db.Uuid
  auditId String     @map("audit_id") @db.Uuid
  audit   Audit      @relation(fields: [auditId], references: [id], onDelete: Cascade)
  url     String
  name    String
  status  PageStatus @default(PENDING)

  findings Finding[]

  @@index([auditId])
  @@map("pages")
}

// ---------------------------------------------------------------------------
// Findings & Evidence
// ---------------------------------------------------------------------------

enum Severity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum FindingStatus {
  NEW
  REVIEWED
  ACCEPTED
  REJECTED
  IGNORED
}

/// Field set matches docs/03's platform-wide Finding contract exactly, plus the documented
/// `businessImpact` extension (see docs/03's "Platform extension" note).
model Finding {
  id                 String        @id @default(uuid()) @db.Uuid
  auditId            String        @map("audit_id") @db.Uuid
  audit              Audit         @relation(fields: [auditId], references: [id], onDelete: Cascade)
  pageId             String        @map("page_id") @db.Uuid
  page               Page          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  projectId          String        @map("project_id") @db.Uuid

  engine             EngineName
  severity           Severity
  /// 0–1. Set once by the Engine, then overwritten by the Confidence Engine's blended score
  /// (docs/03 "Confidence Model") — never presented to the user as the Engine's own unilateral verdict.
  confidence         Float
  category           String?
  title              String
  description        String        @default("")
  expectedResult     String        @map("expected_result")
  actualResult       String        @map("actual_result")
  businessImpact     String        @default("") @map("business_impact")
  suggestedResolution String       @map("suggested_resolution")
  /// AI Engine output (docs/06) — a human-readable explanation generated from this finding's own
  /// fields, never the other way around: "the original finding is never altered by AI output."
  /// Null if the AI Engine wasn't configured, or its provider call failed for this finding.
  aiExplanation      String?       @map("ai_explanation")
  status             FindingStatus @default(NEW)
  createdAt          DateTime      @default(now()) @map("created_at")

  evidence Evidence[]

  @@index([auditId])
  @@index([projectId])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
  @@map("findings")
}

enum EvidenceType {
  SCREENSHOT
  HIGHLIGHTED_SCREENSHOT
  DOM_SNAPSHOT
  HTML_SNAPSHOT
  CSS_SNAPSHOT
  CONSOLE_LOGS
  NETWORK_LOGS
  API_RESPONSE
  TRACE_FILE
}

/// Metadata only, per docs/05 — file bytes live in Supabase Storage at `storagePath`.
model Evidence {
  id          String       @id @default(uuid()) @db.Uuid
  findingId   String       @map("finding_id") @db.Uuid
  finding     Finding      @relation(fields: [findingId], references: [id], onDelete: Cascade)
  type        EvidenceType
  storagePath String       @map("storage_path")
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([findingId])
  @@map("evidence")
}

// ---------------------------------------------------------------------------
// Reports
// ---------------------------------------------------------------------------

enum ReportType {
  DEVELOPER
  MANAGEMENT
  EXECUTIVE
}

/// docs/04 Report Engine "Formats: PDF, HTML, CSV" — HTML isn't a separately generated/downloaded
/// artifact here (the app already renders an equivalent in-browser view live from Audit+Finding
/// data); PDF and CSV are the two real generated files, so those are the two implemented values.
enum ReportFormat {
  PDF
  CSV
}

model Report {
  id            String       @id @default(uuid()) @db.Uuid
  auditId       String       @map("audit_id") @db.Uuid
  audit         Audit        @relation(fields: [auditId], references: [id], onDelete: Cascade)
  projectId     String       @map("project_id") @db.Uuid
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type          ReportType
  /// Phase B addition — the schema originally had no way to distinguish "Developer Report as
  /// PDF" from "Developer Report as CSV" beyond the storage path's file extension. Defaults to
  /// PDF so existing rows/call sites created before this field remain valid.
  format        ReportFormat @default(PDF)
  title         String
  /// PDF/CSV file in Supabase Storage (a dedicated `reports` bucket, not the `evidence` one) —
  /// never generated on demand from a stale audit.
  storagePath   String?      @map("storage_path")
  generatedById String       @map("generated_by_id") @db.Uuid
  generatedBy   User         @relation("ReportGeneratedBy", fields: [generatedById], references: [id])
  generatedAt   DateTime     @default(now()) @map("generated_at")

  @@index([auditId])
  @@index([projectId])
  @@map("reports")
}

// ---------------------------------------------------------------------------
// Platform Settings
// ---------------------------------------------------------------------------

/// Single-row table (per docs/05 "settings" table) — platform-wide, not per-user or per-project.
model PlatformSettings {
  id                     Int     @id @default(1)
  aiProvider             String  @default("Anthropic") @map("ai_provider")
  aiDefaultModel         String  @default("claude-sonnet-5") @map("ai_default_model")
  screenshotQuality      String  @default("High") @map("screenshot_quality")
  defaultTimeoutSeconds  Int     @default(30) @map("default_timeout_seconds")
  retryCount             Int     @default(2) @map("retry_count")
  defaultViewport        String  @default("Desktop (1440x900)") @map("default_viewport")

  @@map("platform_settings")
}
